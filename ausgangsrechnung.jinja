<style>
    /* ============================================================
       Reliable PDF Print Format
       Uses tables for structural layout to prevent wkhtmltopdf 
       from clipping elements off the right side of the page.
       ============================================================ */

    .print-format {
        font-family: Arial, Helvetica, "Liberation Sans", sans-serif;
        font-size: 10pt;
        line-height: 1.35;
        color: #1d1d1d;
        width: 100%;
    }

    /* ---------- Header ---------- */
    .header-block {
        width: 100%;
        margin-bottom: 15mm;
    }
    
    .no-header-spacer {
        height: 35mm; /* Adjust this if you want more/less top margin */
        width: 100%;
    }

    /* ---------- Address & Contact (Table Layout) ---------- */
    .layout-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 15mm;
    }
    .layout-table td {
        vertical-align: top;
    }

    /* Sender/Recipient */
    .address-col {
        width: 72%; /* Increased from 60% to give addresses more horizontal space */
        padding-right: 5mm;
        padding-left: 15mm; 
    }
    #sender {
        margin-bottom: 2mm;
        border-bottom: 0.25pt solid #b0b0b0;
        padding-bottom: 1mm;
        display: inline-block;
        width: 100%; /* Allows the small font line to stretch out fully */
    }
    #sender p {
        margin: 0;
        font-size: 7.5pt;
        color: #555;
        letter-spacing: 0.2pt;
    }
    #recipient {
        font-size: 10.5pt;
        line-height: 1.3;
    }

    /* Contact Info */
    .contact-col {
        width: 28%; /* Reduced from 40% to balance out the extra address space */
        font-size: 8.5pt;
        padding-right: 15mm;
    }
    .contact-col table {
        width: 100%;
    }
    .contact-col table td {
        padding: 0.8mm 0;
    }
    .contact-col table td:first-child {
        color: #555;
        padding-right: 2mm;
    }

    /* Helper utility class used in contact columns & totals */
    .text-right {
        text-align: right;
        white-space: nowrap;
    }

    /* ---------- Main Content ---------- */
    #text {
        padding: 0 15mm;
    }

    #subject {
        margin: 0 0 8mm 0;
    }
    #subject p {
        margin: 0;
        font-size: 11.5pt;
    }
    #subject strong {
        font-weight: 700;
    }

    /* ---------- Item table ---------- */
    .items-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 10mm;
    }
    .items-table th,
    .items-table td {
        padding: 1.6mm 2mm;
        vertical-align: top;
    }
    .items-table thead th {
        text-align: left;
        font-weight: 700;
        padding-bottom: 2mm;
        border-bottom: 1pt solid #1d1d1d;
    }
    .items-table tbody tr:nth-child(even) td {
        color: #666;
        font-size: 8.5pt;
        padding-top: 0;
    }
    .items-table tbody tr:nth-child(even):not(:last-child) td {
        border-bottom: 0.25pt solid #e3e3e3;
    }
    
    /* Target currency/amount columns specifically to force single-line display */
    .items-table tbody tr td:nth-child(5),
    .items-table tbody tr td:last-child,
    .items-table thead th:last-child,
    .items-table tfoot td:last-child {
        text-align: right;
        white-space: nowrap; 
    }
    
    .items-table tfoot tr td {
        padding-top: 1.2mm;
        padding-bottom: 1.2mm;
    }
    .items-table tfoot .grand-total-row td {
        border-top: 0.75pt solid #000;
        font-size: 11pt;
        padding-top: 2.2mm;
    }

    /* ---------- Footer ---------- */
    #footer-html {
        font-size: 8pt;
        color: #555;
        padding: 0 15mm;
    }
    #footer-html .print-format-footer {
        border-top: 0.5pt solid #ccc;
        padding-top: 2mm;
        margin-top: 1mm;
    }
    #pagenum {
        text-align: right;
        margin: 0 0 1mm 0;
    }
</style>

{% set company = frappe.get_doc("Company", doc.company) %}
{% set cmp_addr = frappe.get_doc("Address", doc.company_address) if doc.company_address else None %}
{% set pay_addr = frappe.get_doc("Address", doc.customer_address) if doc.customer_address else None %}

{% if doc.contact_person %}
    {% set contact = frappe.get_doc("Contact", doc.contact_person) %}
{% endif %}

{% if letter_head %}
<div class="header-block">
    {{ letter_head }}
</div>
{% else %}
<div class="no-header-spacer"></div>
{% endif %}

<table class="layout-table">
    <tr>
        <td class="address-col">
            {% if cmp_addr %}
            <div id="sender">
                <p>{{ cmp_addr.address_title }} &#183; {{ cmp_addr.address_line1 }} &#183;
                    {% if cmp_addr.address_line2 %}{{ cmp_addr.address_line2 }} <br>{% endif %}
                    {{ cmp_addr.pincode }} {{ cmp_addr.city }}
                    {% if pay_addr and (cmp_addr.country != pay_addr.country) -%}
                        &#183; {{ cmp_addr.country | upper }}
                    {%- endif %}
                </p>
            </div>
            {% endif %}
            
            <div id="recipient">
                {{ doc.customer_name }}<br />
                {% if contact %}
                        {%- if contact.salutation -%}
                            {{ contact.salutation }}
                        {%- endif %}
                        {%- if contact.salutation in ["Hr.", "Herr"] %}n{% endif %}
                        {{ contact.first_name }} {{ contact.last_name }}<br>
                {% endif %}
                {{ doc.address_display or "" }}
            </div>
        </td>

        <td class="contact-col">
            <table>
                {% if company.phone_no %}
                <tr>
                    <td>{{ _("Phone") }}:</td>
                    <td class="text-right">{{ company.phone_no }}</td>
                </tr>
                {% endif %}

                {% if company.email %}
                <tr>
                    <td>{{ _("Email") }}:</td>
                    <td class="text-right">{{ company.email }}</td>
                </tr>
                {% endif %}

                <tr>
                    <td>{{ _("Date") }}:</td>
                    <td class="text-right">{{ frappe.utils.formatdate(doc.posting_date, "long") }}</td>
                </tr>

                {% if not doc.is_return %}
                <tr>
                    <td>{{ _("Payment Due Date") }}:</td>
                    <td class="text-right">{{ frappe.utils.formatdate(doc.due_date, "long") }}</td>
                </tr>
                {% endif %}

                {% if doc.po_no %}
                <tr>
                    <td>{{ _("Your PO No.") }}:</td>
                    <td class="text-right">{{ doc.po_no }}</td>
                </tr>
                {% endif %}

                {% if doc.tax_id %}
                <tr>
                    <td>{{ _("Your Tax ID") }}:</td>
                    <td class="text-right">{{ doc.tax_id }}</td>
                </tr>
                {% endif %}

                {% if doc.from_date and doc.to_date %}
                <tr>
                    <td>{{ _("Performance Period") }}:</td>
                    {% if doc.from_date.year is defined %}
                        {% set date_format = "dd.mm." if doc.from_date.year == doc.to_date.year else "dd.mm.yy" %}
                    {% else %}
                        {% set date_format = "dd.mm." if doc.from_date[:4] == doc.to_date[:4] else "dd.mm.yy" %}
                    {% endif %}
                    <td class="text-right">{{ frappe.utils.formatdate(doc.from_date, date_format) }} - {{ frappe.utils.formatdate(doc.to_date, "dd.mm.yyyy") }}</td>
                </tr>
                {% endif %}
            </table>
        </td>
    </tr>
</table>

<div id="text">
    <div id="subject">
        {% if doc.is_return %}
            <p><strong>{{ _("Correction Invoice") }} {{ doc.name }}</strong></p>
            <p class="text-small">{{ _("Rectifies invoice {0}").format(doc.return_against) }}</p>
        {% elif doc.amended_from %}
            <p><strong>{{ _("Cancellation Invoice") }} {{ doc.name }}</strong></p>
            <p class="text-small">{{ _("Fully cancels and replaces invoice {0}").format(doc.amended_from) }}</p>
        {% else %}
            <p><strong>{{ _("Invoice") }} {{ doc.name }}</strong></p>
        {% endif %}
    </div>

    <table class="items-table text-small">
        <thead>
            <tr>
                <th style="width: 5%">{{ _("Sr") }}</th>
                <th style="width: 45%">{{ _("Description") }}</th>
                <th style="width: 10%">{{ _("Unit") if not print_settings.print_uom_after_quantity else '&nbsp;'}}</th>
                <th style="width: 10%">{{ _("Qty") }}</th>
                <th style="width: 12%">{{ _("Price") }}</th>
                <th style="width: 18%" class="text-right">{{ _("Amount") }}</th>
            </tr>
        </thead>
        <tbody>
            {% for n in doc.items %}
                <tr>
                    <td>{{ loop.index }}</td>
                    <td><b>{{ _(n.item_name) }}</b></td>
                    <td>{{ _(n.uom) if not print_settings.print_uom_after_quantity else '&nbsp;'}}</td>
                    <td>
                        {{ n.get_formatted("qty") }}
                        {% if print_settings.print_uom_after_quantity %}
                            {{ _(n.uom) }}
                        {% endif %}
                    </td>
                    <td>{{ n.get_formatted("rate") }}</td>
                    <td class="text-right">{{ n.get_formatted("amount") }}</td>
                </tr>
                <tr>
                    <td></td>
                    <td colspan="4">{{ n.description }}</td>
                    <td></td>
                </tr>
            {% endfor %}
        </tbody>

        <tfoot>
            {% if doc.additional_discount_percentage or doc.discount_amount %}
                <tr>
                    <td></td>
                    <td>{{ _("Total") }}</td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td class="text-right">{{ doc.get_formatted("total") }}</td>
                </tr>
                <tr>
                    <td></td>
                    <td>{{ _("Discount") }}</td>
                    <td></td>
                    <td></td>
                    <td>
                        {% if doc.additional_discount_percentage %}
                            {{ doc.get_formatted("additional_discount_percentage") }} &percnt;
                        {% endif %}
                    </td>
                    <td class="text-right">
                        {{ doc.get_formatted("discount_amount") }}
                    </td>
                </tr>
            {% endif %}
            <tr>
                <td></td>
                <td>{{ _("Net Total") }}</td>
                <td></td>
                <td></td>
                <td></td>
                <td class="text-right">{{ doc.get_formatted("net_total") }}</td>
            </tr>
            {% if doc.tax_category == "Reverse Charge" %}
                <tr>
                    <td></td>
                    <td>Steuerschuldnerschaft des Leistungsempfängers / The recipient of the supply is liable for tax</td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td class="text-right"></td>
                </tr>
            {% else %}
                {% for tax_row in doc.taxes %}
                    {% if tax_row.tax_amount or print_settings.print_taxes_with_zero_amount %}
                        <tr>
                            <td></td>
                            <td>{{ tax_row.description }}</td>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td class="text-right">{{ tax_row.get_formatted("tax_amount") }}</td>
                        </tr>
                    {% endif %}
                {% endfor %}

                {% if doc.tax_exemption_reason %}
                    <tr>
                        <td></td>
                        <td>{{ _(doc.tax_exemption_reason) }}</td>
                        <td></td>
                        <td></td>
                        <td colspan="2"></td>
                    </tr>
                {% endif %}
            {% endif %}
            <tr class="grand-total-row">
                <td></td>
                <td><strong>{{ _("Grand Total") }}</strong></td>
                <td></td>
                <td></td>
                <td></td>
                <td class="text-right"><strong>{{ doc.get_formatted("grand_total") }}</strong></td>
            </tr>
            {% if doc.total_advance %}
                <tr>
                    <td></td>
                    <td>{{ _("Total Advance") }}</td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td class="text-right">{{ doc.get_formatted("total_advance") }}</td>
                </tr>
                <tr>
                    <td></td>
                    <td>{{ _("Outstanding Amount") }}</td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td class="text-right">{{ doc.get_formatted("outstanding_amount") }}</td>
                </tr>
            {% endif %}
        </tfoot>
    </table>

    {% if doc.incoterm %}
        <p>{{ _("Terms of delivery") }}: Incoterms® 2020 {{ doc.incoterm }}{% if doc.named_place %} {{ doc.named_place }}{% endif %}</p><br>
    {% endif %}

    {% if doc.terms and (doc.terms | striptags) %}
        <br>
        {{ doc.terms }}
    {% endif %}

    {% if doc.timesheets %}
    <div style="page-break-after: always"></div>
    <div class="timesheets">
        <p style="padding-top: 1em; padding-bottom: 0.33em">
            <strong>{{ _("Time Logs") }}</strong>
        </p>
        <div data-fieldname="timesheets" data-fieldtype="Table">
            <table class="items-table text-small">
                <thead>
                    <tr>
                        <th style="width: 40px">{{ _("Sr") }}</th>
                        <th style="width: 80px;">{{_("Date")}}</th>
                        <th style="width: 370px;">{{_("Note")}}</th>
                        <th style="width: 80px;" class="text-right">{{_("Duration")}}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for time_log in doc.timesheets | sort(attribute="start_date") %}
                    {% set timesheet = frappe.get_doc("Timesheet", time_log.time_sheet)%}
                        {% if timesheet.total_billable_amount > 0 %}
                            <tr style="page-break-inside: avoid;">
                                <td>{{ loop.index }}</td>
                                <td>{{ frappe.utils.formatdate(timesheet.start_date, "dd.mm.yy") }}</td>
                                <td>{{ time_log.description }}</td>
                                <td class="text-right">
                                    {{
                                        frappe.format(
                                            frappe.utils.rounded(time_log.billing_hours * 60) * 60,
                                            {"fieldtype": "Duration"}
                                        )
                                    }}
                                </td>
                            </tr>
                        {% endif %}
                    {% endfor %}
                </tbody>
                <tfoot>
                    <tr>
                        <td></td>
                        <td></td>
                        <td><strong>{{ _("Total Duration") }}</strong></td>
                        <td class="text-right">
                            <strong>
                                {{ 
                                    frappe.format(
                                        frappe.utils.rounded(doc.total_billing_hours * 60) * 60,
                                        {"fieldtype": "Duration", "hide_days": 1}
                                    )
                                }}
                            </strong>
                        </td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
    {% endif %}
</div>

<div id="footer-html" class="visible-pdf">
    <div class="letter-head-footer">
        <p id="pagenum">
            {{ _("Page {0} of {1}").format('<span class="page"></span>', '<span class="topage"></span>') }}
        </p>
        {% if footer %}
        <div class="print-format-footer">
            {{ footer }}
        </div>
        {% endif %}
    </div>
</div>
